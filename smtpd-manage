#!/usr/bin/env bash
# =============================================================================
# smtpd-manage.sh — Full interactive TUI menu system for OpenSMTPD
# =============================================================================
# Backends (in priority order):
#   1. whiptail  (ncurses-based, ships with most Debian/Ubuntu/OpenBSD)
#   2. dialog    (older but very portable)
#   3. plain     (pure bash fallback — no external deps)
#
# Run with no arguments for the interactive menu.
# Pass a subcommand directly for non-interactive/scripted use.
# =============================================================================

set -uo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
R='\033[0;31m' Y='\033[1;33m' G='\033[0;32m'
C='\033[0;36m' B='\033[1m'   D='\033[0m'

log_info()  { echo -e "${C}[info ]${D}  $*"; }
log_ok()    { echo -e "${G}[ok   ]${D}  $*"; }
log_warn()  { echo -e "${Y}[warn ]${D}  $*"; }
log_err()   { echo -e "${R}[error]${D}  $*" >&2; }
log_head()  { echo -e "\n${B}── $* ──${D}"; }
die()       { log_err "$*"; exit 1; }

# ── Sanity checks ─────────────────────────────────────────────────────────────
SMTPCTL=$(command -v smtpctl 2>/dev/null) || die "smtpctl not found in PATH."
SMTPD=$(command -v smtpd 2>/dev/null)     || SMTPD=""

# ── TUI backend detection ─────────────────────────────────────────────────────
if   command -v whiptail &>/dev/null; then TUI=whiptail
elif command -v dialog   &>/dev/null; then TUI=dialog
else                                       TUI=plain
fi

# Dialog geometry
W=70; H=24; MH=16   # width / total height / menu list height

# ── Whiptail colour scheme (NEWT_COLORS) ──────────────────────────────────────
export NEWT_COLORS='
root=,black
window=white,black
border=cyan,black
title=cyan,black
button=black,cyan
actbutton=black,white
listbox=white,black
actlistbox=black,cyan
sellistbox=black,white
actsellistbox=black,white
textbox=white,black
acttextbox=black,cyan
label=white,black
entry=white,black
shadow=,black
'

# =============================================================================
# ── Low-level TUI primitives ──────────────────────────────────────────────────
# =============================================================================

# _menu <title> <text> key1 "Label" key2 "Label" …   → stdout = chosen key
_menu() {
    local title=$1 text=$2; shift 2
    local -a items=("$@")

    if [[ $TUI == plain ]]; then
        echo -e "\n${B}$title${D}"
        echo -e "${C}$text${D}\n"
        local i=0
        local -a keys=() labels=()
        while [[ $i -lt ${#items[@]} ]]; do
            keys+=("${items[$i]}")
            labels+=("${items[$((i+1))]}")
            printf "  %2d) %s\n" $(( i/2 + 1 )) "${items[$((i+1))]}"
            ((i+=2))
        done
        echo
        while true; do
            read -r -p "  Choice (number or key): " ans
            # accept number
            if [[ $ans =~ ^[0-9]+$ ]] && (( ans >= 1 && ans <= ${#keys[@]} )); then
                echo "${keys[$((ans-1))]}"; return 0
            fi
            # accept key directly
            local k; for k in "${keys[@]}"; do
                [[ $k == "$ans" ]] && { echo "$k"; return 0; }
            done
            echo "  Invalid — try again."
        done
    else
        local args=()
        while [[ ${#items[@]} -gt 0 ]]; do
            args+=("${items[0]}" "${items[1]}")
            items=("${items[@]:2}")
        done
        $TUI --title "OpenSMTPD Manager — $title" \
             --menu "$text" $H $W $MH "${args[@]}" \
             3>&1 1>&2 2>&3
    fi
}

# _msg <title> <text>
_msg() {
    local title=$1 text=$2
    if [[ $TUI == plain ]]; then
        echo -e "\n${B}$title${D}\n$text\n"
        read -r -p "  [press Enter] "
    else
        $TUI --title "OpenSMTPD Manager — $title" \
             --msgbox "$text" $H $W
    fi
}

# _confirm <title> <text>   → returns 0=yes / 1=no
_confirm() {
    local title=$1 text=$2
    if [[ $TUI == plain ]]; then
        echo -e "\n${Y}$title${D}\n$text"
        read -r -p "  Confirm? [y/N] " ans
        [[ ${ans,,} == y ]]
    else
        $TUI --title "OpenSMTPD Manager — $title" \
             --yesno "$text" 10 $W
    fi
}

# _input <title> <prompt> <default>   → stdout = entered value
_input() {
    local title=$1 prompt=$2 default=${3:-}
    if [[ $TUI == plain ]]; then
        read -r -p "  $prompt [$default]: " ans
        echo "${ans:-$default}"
    else
        $TUI --title "OpenSMTPD Manager — $title" \
             --inputbox "$prompt" 9 $W "$default" \
             3>&1 1>&2 2>&3
    fi
}

# _passwd <title> <prompt>   → stdout = password
_passwd() {
    local title=$1 prompt=$2
    if [[ $TUI == plain ]]; then
        read -r -s -p "  $prompt: " ans; echo >&2
        echo "$ans"
    else
        $TUI --title "OpenSMTPD Manager — $title" \
             --passwordbox "$prompt" 9 $W \
             3>&1 1>&2 2>&3
    fi
}

# _pager <title> <text>    — scrollable output viewer
_pager() {
    local title=$1 text=$2
    if [[ $TUI == plain ]]; then
        log_head "$title"
        echo -e "$text"
        echo
        read -r -p "  [press Enter] "
    else
        $TUI --title "OpenSMTPD Manager — $title" \
             --scrolltext \
             --msgbox "$text" $H $W
    fi
}

# _gauge <title> <text> <pct>   — progress bar (whiptail/dialog only; plain just prints)
_gauge() {
    local title=$1 text=$2 pct=${3:-50}
    if [[ $TUI == plain ]]; then
        log_info "$text ($pct%)"
    else
        echo "$pct" | $TUI --title "OpenSMTPD Manager — $title" \
            --gauge "$text" 6 $W 0
    fi
}

# run_show <title> <cmd…>  — run a command, display output in pager
run_show() {
    local title=$1; shift
    local out ec=0
    out=$("$@" 2>&1) || ec=$?
    [[ -n $out ]] || out="(no output)"
    [[ $ec -eq 0 ]] || out="EXIT CODE $ec\n\n$out"
    _pager "$title" "$out"
}

# =============================================================================
# ── Helpers ───────────────────────────────────────────────────────────────────
# =============================================================================

daemon_running() { "$SMTPCTL" show stats &>/dev/null; }

daemon_state_label() { daemon_running && echo "RUNNING" || echo "STOPPED"; }

require_root() {
    [[ $EUID -eq 0 ]] || {
        _msg "Permission denied" \
            "This action requires root privileges.\n\nRe-run as root or with sudo."
        return 1
    }
}

_start_smtpd() {
    if [[ -n $SMTPD ]]; then
        "$SMTPD" 2>&1
    elif command -v systemctl &>/dev/null; then
        systemctl start smtpd 2>&1
    elif [[ -x /etc/rc.d/smtpd ]]; then
        /etc/rc.d/smtpd start 2>&1
    else
        echo "ERROR: cannot locate smtpd or a service manager."; return 1
    fi
}

# =============================================================================
# ── Actions ───────────────────────────────────────────────────────────────────
# =============================================================================

# ---- Daemon -----------------------------------------------------------------
act_start() {
    require_root || return
    if daemon_running; then
        _msg "Start" "smtpd is already running."; return
    fi
    _gauge "Start" "Starting smtpd…" 30
    local out; out=$(_start_smtpd 2>&1) && \
        _msg "Start" "smtpd started successfully." || \
        _pager "Start — error" "$out"
}

act_stop() {
    require_root || return
    daemon_running || { _msg "Stop" "smtpd is not running."; return; }
    _confirm "Stop daemon" \
        "Gracefully stop smtpd?\n\nIn-flight messages will remain queued." || return
    run_show "Stop" "$SMTPCTL" stop
}

act_restart() {
    require_root || return
    _confirm "Restart daemon" \
        "Restart smtpd?\n\nActive connections will be dropped." || return
    _gauge "Restart" "Stopping smtpd…" 30
    local out
    out=$("$SMTPCTL" stop 2>&1) || true
    sleep 1
    _gauge "Restart" "Starting smtpd…" 70
    out+=$'\n'"$(_start_smtpd 2>&1)"
    _gauge "Restart" "Done." 100
    _pager "Restart" "$out"
}

act_reload() {
    require_root || return
    daemon_running || { _msg "Reload" "smtpd is not running."; return; }
    run_show "Reload" "$SMTPCTL" reload
}

# ---- Monitoring -------------------------------------------------------------
act_status() {
    if daemon_running; then
        local stats q s
        stats=$("$SMTPCTL" show stats 2>&1)
        q=$(echo "$stats" | grep -E '^(queue|scheduler)' || echo "  (none)")
        s=$(echo "$stats" | grep -E '^(smtp|mta)'        || echo "  (none)")
        _pager "Daemon status" \
"Daemon  : RUNNING

── Queue / Scheduler ─────────────────────────
$q

── SMTP / MTA ────────────────────────────────
$s"
    else
        _msg "Daemon status" \
            "smtpd does not appear to be running\n(or you lack permission to query it)."
    fi
}

act_stats()      { run_show "Runtime statistics" "$SMTPCTL" show stats; }
act_show_queue() { run_show "Queue (verbose)"    "$SMTPCTL" show queue; }

act_log_level() {
    local choice
    choice=$(_menu "Log level" "Select smtpd log verbosity:" \
        brief   "Brief   — minimal logging (default)" \
        verbose "Verbose — show each connection/delivery step" \
        trace   "Trace   — full trace output (very noisy)") || return
    [[ -n $choice ]] || return
    run_show "Log level: $choice" "$SMTPCTL" log "$choice"
}

# ---- Queue ------------------------------------------------------------------
act_queue_stats() {
    run_show "Queue statistics" \
        bash -c '"$SMTPCTL" show stats | grep -E "^(queue|scheduler)"'
}

act_queue_flush() {
    _confirm "Flush queue" \
        "Schedule immediate delivery for ALL queued messages?" || return
    run_show "Queue flush" "$SMTPCTL" schedule all
}

act_queue_hold() {
    _confirm "Hold queue" \
        "Pause outbound MTA delivery?\n\nMessages will accumulate but not be sent." || return
    run_show "Hold queue" "$SMTPCTL" pause mta
}

act_queue_resume() {
    _confirm "Resume queue" "Resume outbound MTA delivery?" || return
    run_show "Resume queue" "$SMTPCTL" resume mta
}

act_bounce() {
    local id
    id=$(_input "Bounce message" "Queue message ID to bounce" "") || return
    [[ -n $id ]] || { _msg "Bounce" "No ID entered — cancelled."; return; }
    _confirm "Bounce $id" \
        "Bounce message '$id'?\n\nThe sender will receive a bounce notice." || return
    run_show "Bounce $id" "$SMTPCTL" bounce "$id"
}

act_remove() {
    local id
    id=$(_input "Remove message" "Queue message ID to permanently remove" "") || return
    [[ -n $id ]] || { _msg "Remove" "No ID entered — cancelled."; return; }
    _confirm "PERMANENT: Remove $id" \
        "Permanently DELETE message '$id' from the queue?\n\nThis cannot be undone. The sender will NOT be notified." || return
    run_show "Remove $id" "$SMTPCTL" remove "$id"
}

act_schedule_one() {
    local id
    id=$(_input "Schedule message" "Queue message ID to schedule for immediate delivery" "") || return
    [[ -n $id ]] || { _msg "Schedule" "No ID entered — cancelled."; return; }
    run_show "Schedule $id" "$SMTPCTL" schedule "$id"
}

# ---- Mail flow --------------------------------------------------------------
act_smtp_flow() {
    local choice
    choice=$(_menu "SMTP listener" "Manage inbound SMTP connections:" \
        pause  "Pause  — stop accepting new connections" \
        resume "Resume — accept connections again") || return
    [[ -n $choice ]] || return
    run_show "SMTP: $choice" "$SMTPCTL" "$choice" smtp
}

act_mta_flow() {
    local choice
    choice=$(_menu "MTA delivery" "Manage outbound MTA delivery:" \
        pause  "Pause  — stop outbound delivery" \
        resume "Resume — resume outbound delivery") || return
    [[ -n $choice ]] || return
    run_show "MTA: $choice" "$SMTPCTL" "$choice" mta
}

# ---- Config -----------------------------------------------------------------
act_check_config() {
    require_root || return
    run_show "Check config" smtpd -n
}

act_show_config() {
    local out
    out=$(smtpd -nv 2>&1 \
        || "$SMTPCTL" show config 2>/dev/null \
        || echo "(unable to retrieve live configuration)")
    _pager "Effective configuration" "$out"
}

act_encrypt_passwd() {
    local pw enc
    pw=$(_passwd "Encrypt password" "Password to encrypt") || return
    [[ -n $pw ]] || { _msg "Encrypt" "No password entered."; return; }
    enc=$(echo "$pw" | "$SMTPCTL" encrypt 2>&1)
    _pager "Encrypted password" "$enc"
}

# =============================================================================
# ── Sub-menus ─────────────────────────────────────────────────────────────────
# =============================================================================

menu_daemon() {
    while true; do
        local state; state=$(daemon_state_label)
        local choice
        choice=$(_menu \
            "Daemon control  [$state]" \
            "Manage the smtpd process  (root required):" \
            start    "Start smtpd" \
            stop     "Gracefully stop smtpd" \
            restart  "Stop then start smtpd" \
            reload   "Reload smtpd.conf without dropping connections" \
            back     "Back  ←  return to main menu") || return
        case $choice in
            start)   act_start   ;;
            stop)    act_stop    ;;
            restart) act_restart ;;
            reload)  act_reload  ;;
            back|"") return      ;;
        esac
    done
}

menu_queue() {
    while true; do
        local choice
        choice=$(_menu \
            "Queue management" \
            "Inspect and control the mail queue:" \
            stats    "Queue statistics" \
            list     "List all queued messages (verbose)" \
            flush    "Flush — deliver all messages now" \
            hold     "Hold  — pause outbound MTA delivery" \
            resume   "Resume outbound MTA delivery" \
            bounce   "Bounce a message by queue ID" \
            remove   "Remove (permanently drop) a message by queue ID" \
            schedule "Schedule one message for immediate delivery" \
            back     "Back  ←  return to main menu") || return
        case $choice in
            stats)    act_queue_stats  ;;
            list)     act_show_queue   ;;
            flush)    act_queue_flush  ;;
            hold)     act_queue_hold   ;;
            resume)   act_queue_resume ;;
            bounce)   act_bounce       ;;
            remove)   act_remove       ;;
            schedule) act_schedule_one ;;
            back|"")  return           ;;
        esac
    done
}

menu_monitoring() {
    while true; do
        local choice
        choice=$(_menu \
            "Monitoring" \
            "View runtime status and diagnostics:" \
            status "Status overview  — daemon, queue, SMTP/MTA summary" \
            stats  "Full stats       — all runtime counters" \
            queue  "Queue (verbose)  — envelope-level listing" \
            log    "Log level        — change verbosity" \
            back   "Back  ←  return to main menu") || return
        case $choice in
            status)  act_status     ;;
            stats)   act_stats      ;;
            queue)   act_show_queue ;;
            log)     act_log_level  ;;
            back|"") return         ;;
        esac
    done
}

menu_flow() {
    while true; do
        local choice
        choice=$(_menu \
            "Mail flow control" \
            "Pause or resume mail acceptance and delivery:" \
            smtp "SMTP listener  — inbound connections (pause / resume)" \
            mta  "MTA delivery   — outbound connections (pause / resume)" \
            back "Back  ←  return to main menu") || return
        case $choice in
            smtp)    act_smtp_flow ;;
            mta)     act_mta_flow  ;;
            back|"") return        ;;
        esac
    done
}

menu_config() {
    while true; do
        local choice
        choice=$(_menu \
            "Config & tools" \
            "Configuration checks and utilities:" \
            check  "Check config    — syntax-check /etc/mail/smtpd.conf" \
            show   "Show config     — print effective running configuration" \
            passwd "Encrypt passwd  — hash a password for smtpd.conf" \
            back   "Back  ←  return to main menu") || return
        case $choice in
            check)   act_check_config   ;;
            show)    act_show_config    ;;
            passwd)  act_encrypt_passwd ;;
            back|"") return             ;;
        esac
    done
}

# =============================================================================
# ── Main menu loop ────────────────────────────────────────────────────────────
# =============================================================================
main_menu() {
    while true; do
        local state; state=$(daemon_state_label)
        local choice
        choice=$(_menu \
            "Main menu  [Daemon: $state]" \
            "OpenSMTPD management console  •  $(hostname)  •  $(date '+%Y-%m-%d %H:%M')" \
            daemon     "Daemon control    — start / stop / restart / reload" \
            queue      "Queue management  — inspect, flush, bounce, remove" \
            monitoring "Monitoring        — status, stats, log levels" \
            flow       "Mail flow         — pause / resume SMTP & MTA" \
            config     "Config & tools    — syntax check, encrypt password" \
            quit       "Quit") || break
        case $choice in
            daemon)     menu_daemon     ;;
            queue)      menu_queue      ;;
            monitoring) menu_monitoring ;;
            flow)       menu_flow       ;;
            config)     menu_config     ;;
            quit|"")    break           ;;
        esac
    done
    [[ $TUI != plain ]] && clear
    echo -e "${C}smtpd-manage${D} — goodbye."
}

# =============================================================================
# ── CLI passthrough (non-interactive) ─────────────────────────────────────────
# =============================================================================
cli_help() {
    cat <<EOF
${B}smtpd-manage.sh${D} — OpenSMTPD interactive TUI + CLI wrapper

Run with no arguments to launch the interactive menu.
TUI backend: ${C}${TUI}${D}  (whiptail › dialog › plain fallback)

${B}Daemon control${D}  (root required)
  start | stop | restart | reload

${B}Monitoring${D}
  status | show-stats | show-queue | log-brief | log-verbose | log-trace

${B}Queue management${D}
  queue-stats | queue-flush | queue-hold | queue-resume
  bounce <id> | remove <id> | schedule <id>

${B}Mail flow${D}
  pause-smtp | resume-smtp | pause-mta | resume-mta

${B}Config & tools${D}  (root required)
  check-config | show-config | encrypt-passwd

${B}Help${D}
  -h | --help | help
EOF
}

# ── Entry point ───────────────────────────────────────────────────────────────
if [[ $# -gt 0 ]]; then
    CMD=$1; shift || true
    case $CMD in
        # daemon
        start)          act_start            ;;
        stop)           act_stop             ;;
        restart)        act_restart          ;;
        reload)         act_reload           ;;
        # monitoring
        status)         act_status           ;;
        show-stats)     act_stats            ;;
        show-queue)     act_show_queue       ;;
        log-brief)      run_show "Log: brief"   "$SMTPCTL" log brief   ;;
        log-verbose)    run_show "Log: verbose" "$SMTPCTL" log verbose ;;
        log-trace)      run_show "Log: trace"   "$SMTPCTL" log trace   ;;
        # queue
        queue-stats)    act_queue_stats      ;;
        queue-flush)    act_queue_flush      ;;
        queue-hold)     act_queue_hold       ;;
        queue-resume)   act_queue_resume     ;;
        bounce)         id=${1:-}
                        [[ -n $id ]] || die "Usage: bounce <id>"
                        run_show "Bounce $id" "$SMTPCTL" bounce "$id"  ;;
        remove)         id=${1:-}
                        [[ -n $id ]] || die "Usage: remove <id>"
                        run_show "Remove $id" "$SMTPCTL" remove "$id"  ;;
        schedule)       id=${1:-}
                        [[ -n $id ]] || die "Usage: schedule <id>"
                        run_show "Schedule $id" "$SMTPCTL" schedule "$id" ;;
        # flow
        pause-smtp)     run_show "Pause SMTP"   "$SMTPCTL" pause  smtp ;;
        resume-smtp)    run_show "Resume SMTP"  "$SMTPCTL" resume smtp ;;
        pause-mta)      run_show "Pause MTA"    "$SMTPCTL" pause  mta  ;;
        resume-mta)     run_show "Resume MTA"   "$SMTPCTL" resume mta  ;;
        # config
        check-config)   act_check_config     ;;
        show-config)    act_show_config      ;;
        encrypt-passwd) act_encrypt_passwd   ;;
        # help
        -h|--help|help) cli_help             ;;
        *) die "Unknown command: '$CMD'  —  run '$(basename "$0") --help' for usage." ;;
    esac
else
    main_menu
fi
